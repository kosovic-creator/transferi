generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Relacija {
  APARTMAN_AERODROM @map("apartman-aerodrom")
  AERODROM_APARTMAN @map("aerodrom-apartman")
}

model Transfer {
  id       String   @id @default(uuid())
  relacija Relacija
  brojLetaNapomena String?
  iznos    Float    @default(20.0)
  datum    DateTime @db.Date
  vrijeme  DateTime @db.Time(0)
  korisnik String?
  brojTelefona String?
  datumVrijemeUtc DateTime
  alarmEnabled Boolean @default(true)
  alarmSentAt DateTime?

  @@index([datumVrijemeUtc, alarmSentAt])

}

model ArhivaTransfera {
  id       String   @id @default(uuid())
  relacija Relacija
  brojLetaNapomena String?
  iznos    Float    @default(20.0)
  datum    DateTime @db.Date
  vrijeme  DateTime @db.Time(0)
  korisnik String?
  brojTelefona String?
  datumVrijemeUtc DateTime
  alarmEnabled Boolean @default(true)
  alarmSentAt DateTime?
}

model ChatSettings {
  id        Int      @id @default(1)
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}
