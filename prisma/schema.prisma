generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Relacija {
  APARTMAN_AERODROM @map("apartman-aerodrom")
  AERODROM_APARTMAN @map("aerodrom-apartman")
}

model Transfer {
  id       String   @id @default(uuid())
  relacija Relacija
  ostaleRelacije String?
  iznos    Float    @default(20.0)
  datum    DateTime @db.Date
  vrijeme  DateTime @db.Time(0)
  korisnik String?
  datumVrijemeUtc DateTime
  alarmEnabled Boolean @default(true)
  alarmSentAt DateTime?

  @@index([datumVrijemeUtc, alarmSentAt])

}

model ArhivaTransfera {
  id       String   @id @default(uuid())
  relacija Relacija
  ostaleRelacije String?
  iznos    Float    @default(20.0)
  datum    DateTime @db.Date
  vrijeme  DateTime @db.Time(0)
  korisnik String?
  datumVrijemeUtc DateTime
  alarmEnabled Boolean @default(true)
  alarmSentAt DateTime?
}

model PushSubscription {
  id        String   @id @default(uuid())
  userKey   String
  endpoint  String   @unique
  p256dhKey String
  authKey   String
  createdAt DateTime @default(now())

  @@index([userKey])
}
